# Server
PORT=5512
NODE_ENV=development
SERVER_URL=http://localhost:5512
FRONTEND_URL=http://localhost:3000
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
# COOKIE_DOMAIN=example.com

# MongoDB
DB_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority

# Initial super admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_FULL_NAME=System Admin

# JWT
JWT_SECRET=replace_with_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_EXPIRES_IN_DAYS=7

# Refresh token
REFRESH_TOKEN_SECRET=replace_with_at_least_32_characters
REFRESH_TOKEN_EXPIRES_IN=7d

# Password reset token
PASSWORD_RESET_SECRET=replace_with_at_least_32_characters

# Global rate limiting
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=120

# Route-specific rate limiting
THROTTLE_LOGIN_TTL_MS=30000
THROTTLE_LOGIN_LIMIT=5
THROTTLE_REFRESH_TTL_MS=60000
THROTTLE_REFRESH_LIMIT=30
THROTTLE_OTP_TTL_MS=60000
THROTTLE_OTP_LIMIT=5
THROTTLE_RESET_TTL_MS=900000
THROTTLE_RESET_LIMIT=3

# Imgur
IMGUR_CLIENT_ID=your_imgur_client_id

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_mail_app_password
MAIL_FROM='"AL-TASK" <your_email@example.com>'
MAIL_SECURE=false
MAIL_TRANSPORT=smtp
MAIL_IGNORE_TLS=true
MAIL_REQUIRE_TLS=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:5512/auth/google/redirect

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID_SANDBOX=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET_SANDBOX=your_paypal_sandbox_client_secret
PAYPAL_CLIENT_ID_LIVE=your_paypal_live_client_id
PAYPAL_CLIENT_SECRET_LIVE=your_paypal_live_client_secret

# PayOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
